{
  "name": "mailvoyage",
  "description": "MailVoyage - A modern email client with offline-first architecture",
  "version": "2026.3.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:web": "vite",
    "dev:api": "npm --prefix api run dev",
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "build": "tsc && vite build",
    "build:api": "npm --prefix api run build",
    "build:all": "npm run build && npm run build:api",
    "preview": "vite preview",
    "preview:prod": "vite preview --port 4173 --host",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:api": "npm --prefix api run test",
    "test:phase1": "vitest run --config vitest.config.ts tests/phase1 --passWithNoTests",
    "test:phase2": "vitest run --config vitest.config.ts tests/phase2 --passWithNoTests",
    "test:phase3": "npm --prefix api run test:phase3",
    "test:phase4": "npm --prefix api run test:phase4",
    "test:phase5:web": "vitest run --config vitest.config.ts tests/phase5 --passWithNoTests",
    "test:phase5:api": "npm --prefix api run test:phase5",
    "test:phase5": "npm run test:phase5:web && npm run test:phase5:api",
    "test:all:phases": "npm run test:phase1 && npm run test:phase2 && npm run test:phase3 && npm run test:phase4 && npm run test:phase5",
    "test:coverage:all": "npm run test:coverage && npm --prefix api run test:coverage",
    "test:clean": "rimraf coverage .vitest api/coverage api/.vitest",
    "test:ui": "node scripts/test-runner-ui.mjs",
    "install:api": "npm --prefix api install",
    "install:all": "npm install && npm run install:api",
    "start:api": "npm --prefix api run start",
    "clean": "rimraf dist node_modules/.cache",
    "clean:all": "rimraf dist node_modules api/dist api/node_modules",
    "version:bump": "node scripts/bump-version.mjs",
    "release": "node scripts/bump-version.mjs && npm run lint && npm run build:all",
    "release:quick": "node scripts/bump-version.mjs && npm run build",
    "prerelease": "echo '\n🚀  Starting MailVoyage release build...\n'"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-react": "^11.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "ckeditor5": "^47.4.0",
    "dexie": "^4.2.1",
    "dompurify": "^3.2.7",
    "framer-motion": "^12.9.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.1",
    "react-router-dom": "^7.5.2",
    "react-toastify": "^11.0.5",
    "tailwind-animate": "^0.2.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/dompurify": "^3.0.5",
    "@types/imapflow": "^1.0.21",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
